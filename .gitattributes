# Auto-detect text files and normalize line endings
* text=auto

# Force text files to use LF line endings in the repo
*.cpp text eol=lf
*.h text eol=lf
*.cs text eol=lf
*.uproject text eol=lf
*.uplugin text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.txt text eol=lf

# Treat binary files properly
*.png binary
*.jpg binary
*.jpeg binary
*.mp3 binary
*.wav binary
*.uasset binary
*.umap binary

# Optional: Don't diff or merge these
*.uasset -diff -merge
*.umap -diff -merge

